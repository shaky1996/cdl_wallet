{
    "expo": {
      "name": "CDL Wallet",
      "slug": "cdl-wallet",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/icon.png",
      "splash": { "backgroundColor": "#111214" },
      "ios": {
        "bundleIdentifier": "com.yourname.cdlwallet",
        "infoPlist": {
          "NSCameraUsageDescription": "Take a photo of your CDL or med card",
          "NSPhotoLibraryUsageDescription": "Upload your CDL or med card from photos"
        }
      },
      "android": {
        "package": "com.yourname.cdlwallet",
        "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
      },
      "plugins": [
        "expo-notifications",
        "expo-local-authentication"
      ]
    }
  }